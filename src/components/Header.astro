---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<a class="brand" href="/">
		<div class="tomato-logo">🍅</div>
		<div>
			<div class="brand-title">Home Grown Tomatoes</div>
			<div class="brand-tagline">Grow better. Eat better.</div>
		</div>
	</a>

	<nav class="main-nav">
		<a class={currentPath === "/" ? "active" : ""} href="/">Start Here</a>
		<a class={currentPath === "/growing-guides" ? "active" : ""} href="/growing-guides">Growing Guides</a>
		<a class={currentPath === "/tomato-problems" ? "active" : ""} href="/tomato-problems">Tomato Problems</a>
		<a class={currentPath === "/product-reviews" ? "active" : ""} href="/product-reviews">Product Reviews</a>
		<a class={currentPath === "/about" ? "active" : ""} href="/about">About</a>
	</nav>

	<div class="header-social">
		<a href="https://facebook.com" target="_blank" aria-label="Facebook">
			<svg viewBox="0 0 24 24"><path d="M22 12.06C22 6.48 17.52 2 11.94 2S2 6.48 2 12.06c0 5.03 3.68 9.2 8.5 9.94v-7.03H7.97v-2.91h2.53V9.84c0-2.5 1.49-3.88 3.77-3.88 1.09 0 2.23.2 2.23.2v2.45h-1.25c-1.24 0-1.63.77-1.63 1.56v1.89h2.78l-.44 2.91h-2.34V22c4.82-.74 8.38-4.91 8.38-9.94z" /></svg>
		</a>

		<a href="https://instagram.com" target="_blank" aria-label="Instagram">
			<svg viewBox="0 0 24 24"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3.5A4.5 4.5 0 1 1 12 16.5 4.5 4.5 0 0 1 12 7.5zm0 2A2.5 2.5 0 1 0 12 14.5 2.5 2.5 0 0 0 12 9.5zM17.75 6.5a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z" /></svg>
		</a>

		<a href="https://pinterest.com" target="_blank" aria-label="Pinterest">
			<svg viewBox="0 0 24 24"><path d="M12.04 2C6.58 2 3 5.64 3 10.52c0 3.62 2.03 5.74 3.2 5.74.48 0 .76-1.34.76-1.72 0-.45-1.15-1.41-1.15-3.29 0-3.9 2.96-6.66 6.81-6.66 3.3 0 5.74 1.88 5.74 5.32 0 2.57-1.03 7.39-4.37 7.39-1.2 0-2.23-.87-1.92-2.14.37-1.52 1.08-3.16 1.08-4.26 0-2.77-3.93-2.27-3.93 1.08 0 1.05.36 1.76.36 1.76s-1.22 5.18-1.44 6.09c-.43 1.81-.06 4.03-.03 4.25.02.13.18.16.25.06.1-.13 1.39-1.73 1.83-3.33.12-.45.71-2.78.71-2.78.35.67 1.38 1.26 2.47 1.26 3.25 0 5.46-2.96 5.46-6.93C18.83 5.35 16.29 2 12.04 2z" /></svg>
		</a>

		<a href="/search" aria-label="Search">
			<svg viewBox="0 0 24 24"><path d="M10.5 4a6.5 6.5 0 0 1 5.15 10.46l4.45 4.44-1.41 1.42-4.45-4.45A6.5 6.5 0 1 1 10.5 4zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9z" /></svg>
		</a>
	</div>
</header>

<style is:global>
	.site-header {
		height: 100px;
		background: #fffdf8;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 32px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
		position: relative;
		z-index: 10;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 14px;
		text-decoration: none;
		color: #102810;
		flex-shrink: 0;
	}

	.tomato-logo {
		font-size: 54px;
		line-height: 1;
	}

	.brand-title {
		font-size: 26px;
		font-weight: 800;
		line-height: 1.1;
	}

	.brand-tagline {
		font-size: 15px;
		color: #315c16;
		margin-top: 3px;
	}

	.main-nav {
		display: flex;
		align-items: center;
		gap: 34px;
	}

	.main-nav a {
		color: #102810;
		text-decoration: none;
		font-weight: 600;
		padding: 39px 0 28px;
		border-bottom: 4px solid transparent;
	}

	.main-nav a.active {
		color: #456b17;
		border-bottom-color: #6f9633;
	}

	.header-social {
	display: flex !important;
	flex-direction: row !important;
	align-items: center !important;
	justify-content: flex-end !important;
	gap: 22px !important;
	width: auto !important;
	min-width: 130px !important;
	}

.header-social a {
	display: flex !important;
	align-items: center !important;
	justify-content: center !important;
	width: 24px !important;
	height: 24px !important;
	padding: 0 !important;
	margin: 0 !important;
	color: #102810 !important;
	text-decoration: none !important;
	border: none !important;
	}

.header-social svg {
	width: 24px !important;
	height: 24px !important;
	min-width: 24px !important;
	display: block !important;
	fill: currentColor !important;
	}

	.header-social a:hover {
		color: #456b17;
	}
</style>
