---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="hero-content">
					<h1>Grow Better<br />Tomatoes at Home</h1>
					<div class="divider">🌱</div>
					<p>Simple, practical advice to help you grow delicious, healthy tomatoes in any space.</p>
					<a class="hero-button" href="/growing-guides">Start Growing Today</a>
				</div>
			</section>

			<section class="popular">
				<div class="section-header">
					<h2>Most Popular Articles</h2>
					<a href="/growing-guides">View all articles →</a>
				</div>

				<div class="article-grid">
					<article class="card">
						<img src="/images/pots/pots-1-hero.webp" alt="Tomatoes growing in a large pot on a sunny patio" />
						<div class="card-body">
							<span>Growing Guides</span>
							<h3>How to Grow Tomatoes in Pots</h3>
							<p>Everything you need to know to grow healthy tomatoes in containers.</p>
							<a href="/blog/grow-tomatoes-in-pots">Read more →</a>
						</div>
					</article>

					<article class="card">
						<img src="/images/yellow-leaves/yellow-leaves-1-hero.webp" alt="Tomato plant with yellow lower leaves" />
						<div class="card-body">
							<span>Tomato Problems</span>
							<h3>Why Are My Tomato Leaves Turning Yellow?</h3>
							<p>Learn the common causes of yellow tomato leaves and how to fix them.</p>
							<a href="/blog/why-are-my-tomato-leaves-turning-yellow">Read more →</a>
						</div>
					</article>

					<article class="card">
						<img
							src="/images/raised-beds/raised-beds-1-hero.webp"
							alt="Healthy tomato plants growing in a wooden raised bed garden with ripe red tomatoes"
						/>
						<div class="card-body">
							<span>Growing Guides</span>
							<h3>How to Grow Tomatoes in Raised Beds</h3>
							<p>Step-by-step guide to planting, feeding and caring for tomatoes in raised beds.</p>
							<a href="/blog/grow-tomatoes-in-raised-beds">Read more →</a>
						</div>
					</article>

					<article class="card">
						<img src="/images/home-page/tomato-varieties.webp" alt="Different tomato varieties" />
						<div class="card-body">
							<span>Varieties</span>
							<h3>Best Tomato Varieties for Home Gardens</h3>
							<p>Our favourite tomato varieties for flavour, yield and easy growing.</p>
							<a href="/blog/tomato-varieties/best-varieties-for-gardens">Read more →</a>
						</div>
					</article>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
