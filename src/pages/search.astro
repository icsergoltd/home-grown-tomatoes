---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Search - Home Grown Tomatoes" description="Search Home Grown Tomatoes." />
	</head>
	<body>
		<Header />

		<main class="page">
			<h1>Search</h1>
			<p>Search functionality is coming soon.</p>

			<input type="text" placeholder="Search tomato guides..." />
		</main>

		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: 1000px;
		margin: 80px auto;
		padding: 20px;
	}

	input {
		width: 100%;
		padding: 16px;
		font-size: 18px;
		border: 1px solid #ddd;
		border-radius: 8px;
	}
</style>