---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Tomato Problems - Home Grown Tomatoes" description="Troubleshooting guides for common tomato plant problems." />
	</head>
	<body>
		<Header />

		<main class="page">
			<h1>Tomato Problems</h1>
			<p>Identify and fix common tomato plant problems before they ruin your harvest.</p>

			<h2>Common Problems</h2>

			<div class="problem-grid">
				<a class="problem-card" href="/blog/why-are-my-tomato-leaves-turning-yellow">
					<img src="/images/yellow-leaves-1-hero.png" alt="Tomato plant with yellow lower leaves" />
					<div>
						<span>Tomato Problems</span>
						<h3>Why Are My Tomato Leaves Turning Yellow?</h3>
						<p>Learn the common causes of yellow tomato leaves and how to fix them.</p>
					</div>
				</a>

				<div class="problem-card placeholder">
					<h3>Blossom End Rot</h3>
					<p>Coming soon.</p>
				</div>

				<div class="problem-card placeholder">
					<h3>Tomato Blight</h3>
					<p>Coming soon.</p>
				</div>

				<div class="problem-card placeholder">
					<h3>Leaf Curl</h3>
					<p>Coming soon.</p>
				</div>

				<div class="problem-card placeholder">
					<h3>Cracked Tomatoes</h3>
					<p>Coming soon.</p>
				</div>

				<div class="problem-card placeholder">
					<h3>Pests on Tomato Plants</h3>
					<p>Coming soon.</p>
				</div>
			</div>

			<p class="closing">These guides will help you understand what is happening and what to do next.</p>
		</main>

		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: 1100px;
		margin: 80px auto;
		padding: 20px;
	}

	.page h1 {
		font-size: clamp(2.4rem, 5vw, 4rem);
		margin-bottom: 16px;
		color: #102810;
	}

	.page > p {
		font-size: 1.15rem;
		line-height: 1.7;
		color: #333;
		max-width: 760px;
	}

	.page h2 {
		margin-top: 48px;
		margin-bottom: 24px;
		font-size: 2rem;
		color: #102810;
	}

	.problem-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 28px;
		margin-top: 24px;
	}

	.problem-card {
		display: block;
		background: #fffdf8;
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
		color: #102810;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.problem-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
	}

	.problem-card img {
		width: 100%;
		height: 190px;
		object-fit: cover;
		display: block;
	}

	.problem-card div {
		padding: 22px;
	}

	.problem-card span {
		display: inline-block;
		background: #6f9633;
		color: white;
		font-weight: 800;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 8px 12px;
		border-radius: 6px;
		margin-bottom: 14px;
	}

	.problem-card h3 {
		font-size: 1.45rem;
		line-height: 1.15;
		margin: 0 0 12px;
	}

	.problem-card p {
		color: #333;
		line-height: 1.6;
		margin: 0;
	}

	.placeholder {
		padding: 24px;
		box-shadow: inset 0 0 0 1px #e5e5e5;
		background: white;
	}

	.placeholder:hover {
		transform: none;
		box-shadow: inset 0 0 0 1px #e5e5e5;
	}

	.closing {
		margin-top: 40px;
	}
</style>
