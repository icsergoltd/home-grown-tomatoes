---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.tags?.includes('growing guides'))
	.sort((a, b) => {
		const aOrder = a.data.order ?? 999;
		const bOrder = b.data.order ?? 999;

		if (aOrder !== bOrder) {
			return aOrder - bOrder;
		}

		return a.data.title.localeCompare(b.data.title);
	});

const getPostUrl = (post) => `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Growing Guides - Home Grown Tomatoes" description="Tomato growing guides for home gardeners." />
	</head>
	<body>
		<Header />

		<main class="page">
			<section class="page-hero">
				<h1>Growing Guides</h1>
				<p>Step-by-step tomato growing guides for beginners and experienced gardeners alike.</p>
			</section>

			<div class="guide-list">
				{posts.map((post) => (
					<a class="guide-card" href={getPostUrl(post)}>
						<div class="guide-image">
							{post.data.heroImage ? (
								<img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
							) : (
								<div class="guide-placeholder">🍅</div>
							)}
						</div>

						<div class="guide-content">
							<span class="guide-label">Growing Guide</span>
							<h2>{post.data.title}</h2>
							<p>{post.data.description}</p>
							<span class="read-more">Read guide →</span>
						</div>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	.page {
		max-width: 1100px;
		margin: 80px auto;
		padding: 20px;
	}

	.page-hero {
		margin-bottom: 44px;
	}

	.page-hero h1 {
		font-size: clamp(2.4rem, 5vw, 4.2rem);
		line-height: 1.05;
		margin-bottom: 18px;
		color: #121212;
	}

	.page-hero p {
		font-size: 1.15rem;
		max-width: 760px;
		color: #243024;
	}

	.guide-list {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 28px;
	}

	.guide-card {
		display: block;
		background: #ffffff;
		border-radius: 18px;
		overflow: hidden;
		text-decoration: none;
		color: #102810;
		box-shadow: 0 6px 22px rgba(0, 0, 0, 0.09);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.guide-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.14);
	}

	.guide-image {
		width: 100%;
		aspect-ratio: 16 / 9;
		background: #f4f1ea;
		overflow: hidden;
	}

	.guide-image img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.guide-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 4rem;
		background: #f4f1ea;
	}

	.guide-content {
		padding: 24px;
	}

	.guide-label {
		display: inline-block;
		margin-bottom: 12px;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #5f7f2a;
	}

	.guide-card h2 {
		font-size: 1.45rem;
		line-height: 1.25;
		margin: 0 0 14px;
		color: #0f1b0f;
	}

	.guide-card p {
		margin: 0;
		line-height: 1.7;
		color: #4b4b4b;
	}

	.read-more {
		display: inline-block;
		margin-top: 18px;
		font-weight: 700;
		color: #456b17;
	}

	@media (max-width: 800px) {
		.page {
			margin: 50px auto;
			padding: 18px;
		}

		.guide-list {
			grid-template-columns: 1fr;
		}
	}
</style>
